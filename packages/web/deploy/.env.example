# 部署环境变量示例
# 复制此文件为 .env 并填写实际值

# 服务器配置
REMOTE_HOST=your-server.com
REMOTE_USER=deploy
REMOTE_PATH=/var/www/mindflow

# 域名配置
DOMAIN=https://md.mengbin.top

# SSL 证书路径（如果使用自签名证书）
SSL_CERT_PATH=/etc/nginx/ssl/md.mengbin.top.crt
SSL_KEY_PATH=/etc/nginx/ssl/md.mengbin.top.key

# 数据库配置（如果需要）
# DATABASE_URL=

# 其他环境变量
# NODE_ENV=production
