platform :ios, '13.0'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', '..', 'ios', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "Missing FLUTTER_ROOT in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['SWIFT_VERSION'] = '5.0'
    end
  end

  # Ensure ALL xcconfig files have a consistent SWIFT_VERSION = 5.0.
  # This prevents CocoaPods from finding "multiple SWIFT_VERSION per target" when
  # Runner's target inherits from both Debug.xcconfig and Release.xcconfig
  # (which define SWIFT_VERSION) and also from Generated.xcconfig.
  Dir.glob(File.join(installer.sandbox_root, '**', '*.xcconfig')).each do |path|
    lines = File.readlines(path)
    # Remove existing SWIFT_VERSION lines
    clean = lines.reject { |l| l =~ /\bSWIFT_VERSION\b/ }
    File.write(path, clean.join + "SWIFT_VERSION = 5.0;\n")
  end
end
